generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleName {
  ADMIN
  AGRICULTOR
  SUPERVISOR
  INSTITUCION
  TECNICO
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

enum WaterLevel {
  EMPTY
  LOW
  MEDIUM
  FULL
}

enum SystemHealth {
  OK
  WARNING
  ERROR
  CRITICAL
}

enum CommandTarget {
  water_pump
  fertilizer_pump
}

enum CommandState {
  ON
  OFF
}

enum CommandStatus {
  pending
  delivered
  executed
  rejected
}

enum AlertType {
  HUMEDAD_BAJA
  FERTILIDAD_BAJA
  TANQUE_VACIO
  SISTEMA_CON_PROBLEMAS
  DISPOSITIVO_OFFLINE
  CUSTOM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  open
  resolved
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  profile      Profile?
  roles        UserRole[]
  plots        UserPlot[]
  ownedPlots   Plot[]     @relation("PlotOwner")
  reports      Report[]
  auditLogs    AuditLog[]

  @@index([isActive])
  @@index([createdAt])
}

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  fullName        String
  phone           String?
  institutionName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        RoleName   @unique
  description String?
  users       UserRole[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Plot {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  location         String?
  cropType         String?
  area             Decimal?           @db.Decimal(12, 2)
  ownerId          String             @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  owner            User               @relation("PlotOwner", fields: [ownerId], references: [id])
  users            UserPlot[]
  devices          Device[]
  irrigationRule   IrrigationRule?
  alerts           Alert[]
  irrigationEvents IrrigationEvent[]
  reports          Report[]

  @@index([ownerId])
  @@index([createdAt])
}

model UserPlot {
  userId    String   @db.Uuid
  plotId    String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plot      Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@id([userId, plotId])
  @@index([plotId])
}

model Device {
  id              String             @id @default(uuid()) @db.Uuid
  deviceCode      String             @unique
  deviceName      String
  firmwareVersion String?
  status          DeviceStatus       @default(OFFLINE)
  lastSeenAt      DateTime?
  plotId          String             @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  plot            Plot               @relation(fields: [plotId], references: [id])
  telemetry       Telemetry[]
  pendingCommands PendingCommand[]
  alerts          Alert[]
  irrigationEvents IrrigationEvent[]

  @@index([plotId])
  @@index([status])
  @@index([lastSeenAt])
}

model Telemetry {
  id               String       @id @default(uuid()) @db.Uuid
  deviceId         String       @db.Uuid
  soilMoisture     Decimal?     @db.Decimal(6, 2)
  soilFertility    Decimal?     @db.Decimal(6, 2)
  soilTemperature  Decimal?     @db.Decimal(6, 2)
  airTemperature   Decimal?     @db.Decimal(6, 2)
  airHumidity      Decimal?     @db.Decimal(6, 2)
  waterLevel       WaterLevel?
  waterPumpOn      Boolean      @default(false)
  fertilizerPumpOn Boolean      @default(false)
  systemHealth     SystemHealth @default(OK)
  createdAt        DateTime     @default(now())
  device           Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@index([createdAt])
  @@index([systemHealth])
  @@index([waterLevel])
}

model PendingCommand {
  id          String        @id @default(uuid()) @db.Uuid
  deviceId    String        @db.Uuid
  target      CommandTarget
  state       CommandState
  durationSec Int?
  status      CommandStatus @default(pending)
  createdAt   DateTime      @default(now())
  deliveredAt DateTime?
  executedAt  DateTime?
  device      Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  events      IrrigationEvent[]

  @@index([deviceId, status, createdAt])
  @@index([status, createdAt])
}

model Alert {
  id         String        @id @default(uuid()) @db.Uuid
  plotId     String        @db.Uuid
  deviceId   String?       @db.Uuid
  type       AlertType
  severity   AlertSeverity
  title      String
  message    String
  status     AlertStatus   @default(open)
  createdAt  DateTime      @default(now())
  resolvedAt DateTime?
  plot       Plot          @relation(fields: [plotId], references: [id], onDelete: Cascade)
  device     Device?       @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([plotId, status, createdAt])
  @@index([deviceId])
  @@index([severity])
  @@index([type])
}

model IrrigationRule {
  id                    String   @id @default(uuid()) @db.Uuid
  plotId                String   @unique @db.Uuid
  minSoilMoisture       Decimal  @db.Decimal(6, 2)
  maxSoilMoisture       Decimal  @db.Decimal(6, 2)
  autoIrrigationEnabled Boolean  @default(false)
  readingIntervalSec    Int      @default(60)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  plot                  Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
}

model IrrigationEvent {
  id          String          @id @default(uuid()) @db.Uuid
  plotId      String          @db.Uuid
  deviceId    String?         @db.Uuid
  commandId   String?         @db.Uuid
  eventType   String
  durationSec Int?
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime        @default(now())
  plot        Plot            @relation(fields: [plotId], references: [id], onDelete: Cascade)
  device      Device?         @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  command     PendingCommand? @relation(fields: [commandId], references: [id], onDelete: SetNull)

  @@index([plotId, startedAt])
  @@index([deviceId, startedAt])
  @@index([commandId])
  @@index([createdAt])
}

model Report {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  plotId      String?  @db.Uuid
  type        String
  periodStart DateTime
  periodEnd   DateTime
  generatedAt DateTime @default(now())
  metadata    Json?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  plot        Plot?    @relation(fields: [plotId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([plotId])
  @@index([type, generatedAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  action      String
  entity      String
  entityId    String?
  description String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([action])
}
